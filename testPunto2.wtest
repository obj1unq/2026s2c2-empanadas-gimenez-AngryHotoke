import empleados.*

test "Qué hacen los empleados con lo que cobran" {
	
  baigorria.venta(500)
  galvan.sueldo(20000)
  baigorria.venta(300)
  gimenez.pagar(baigorria)
  gimenez.pagar(galvan)
  
  baigorria.venta(100)
  gimenez.pagar(baigorria)
  assert.equals(13500, baigorria.totalCobrado())
  
 	
}